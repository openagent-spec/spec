{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagent.dev/schemas/agent/v1",
  "title": "Agent Manifest",
  "description": "Agent Manifest v1 — defines an AI agent's identity, persona, capabilities, and marketplace metadata.",
  "type": "object",
  "required": ["id", "name", "version", "description", "persona"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,62}[a-z0-9]$",
      "description": "Unique agent identifier (lowercase, dots, hyphens, underscores)."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Display name."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
      "description": "Semantic version (e.g. 1.0.0, 1.2.3-beta.1)."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "One-line description of what this agent does."
    },
    "emoji": {
      "type": "string",
      "maxLength": 8,
      "description": "Signature emoji."
    },
    "avatar": {
      "type": "string",
      "description": "Workspace-relative path, http(s) URL, or data URI."
    },
    "author": {
      "type": "string",
      "description": "Author identifier (username or org)."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier or 'proprietary'."
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage URL."
    },
    "repository": {
      "type": "string",
      "description": "Source repository URL."
    },
    "persona": {
      "$ref": "#/$defs/Persona"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/SkillRef" },
      "description": "Skills this agent uses."
    },
    "adapters": {
      "$ref": "#/$defs/Adapters"
    },
    "model": {
      "$ref": "#/$defs/ModelRequirements"
    },
    "experience": {
      "$ref": "#/$defs/Experience"
    },
    "collaboration": {
      "$ref": "#/$defs/Collaboration"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeRequirements"
    },
    "marketplace": {
      "$ref": "#/$defs/Marketplace"
    }
  },
  "$defs": {
    "Persona": {
      "type": "object",
      "required": ["style", "tone"],
      "additionalProperties": false,
      "properties": {
        "style": {
          "type": "string",
          "description": "Personality style (e.g. 'INTJ, logic-driven')."
        },
        "language": {
          "type": "array",
          "items": { "type": "string" },
          "description": "BCP-47 language codes (e.g. ['zh', 'en'])."
        },
        "tone": {
          "type": "string",
          "description": "Communication tone."
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Behavioral principles."
        }
      }
    },
    "SkillRef": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill name (e.g. 'coding-agent')."
        },
        "version": {
          "type": "string",
          "description": "Semver range (e.g. '^1.0')."
        }
      }
    },
    "Adapters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frameworks": {
          "type": "array",
          "items": { "$ref": "#/$defs/FrameworkRef" },
          "description": "Supported agent frameworks / runtimes."
        },
        "tools": {
          "$ref": "#/$defs/ToolRequirements"
        },
        "agent_apps": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentAppRef" },
          "description": "Sub-agent tools that can be invoked."
        },
        "services": {
          "type": "array",
          "items": { "$ref": "#/$defs/ServiceDep" },
          "description": "External service dependencies."
        }
      }
    },
    "FrameworkRef": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Framework name (e.g. 'openclaw', 'langchain', 'crewai')."
        },
        "version": {
          "type": "string",
          "description": "Version constraint."
        },
        "native": {
          "type": "boolean",
          "description": "True if natively supported (no adapter needed)."
        },
        "adapter": {
          "type": "string",
          "description": "Path to adapter config file."
        }
      }
    },
    "ToolRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolRef" },
          "description": "Must-have tools."
        },
        "recommended": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolRef" },
          "description": "Nice-to-have tools."
        },
        "optional": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolRef" },
          "description": "Use if available."
        }
      }
    },
    "ToolRef": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name."
        },
        "reason": {
          "type": "string",
          "description": "Why this tool is needed."
        }
      }
    },
    "AgentAppRef": {
      "type": "object",
      "required": ["name", "role"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent app name (e.g. 'claude-code', 'codex')."
        },
        "role": {
          "type": "string",
          "description": "What role this app fills (e.g. 'coding', 'web-automation')."
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether this app is mandatory."
        },
        "alternatives": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alternative apps that can fill the same role."
        }
      }
    },
    "ServiceDep": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Service name."
        },
        "type": {
          "type": "string",
          "enum": ["api", "runtime", "database", "storage"],
          "description": "Dependency type."
        },
        "version": {
          "type": "string",
          "description": "Version constraint."
        },
        "auth": {
          "type": "string",
          "description": "How to authenticate."
        }
      }
    },
    "ModelRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum": {
          "type": "string",
          "description": "Minimum model tier (e.g. 'haiku', 'sonnet')."
        },
        "recommended": {
          "type": "string",
          "description": "Recommended model tier (e.g. 'opus')."
        },
        "context_window": {
          "type": "string",
          "description": "Minimum context window (e.g. '200k')."
        }
      }
    },
    "Experience": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["junior", "mid", "senior", "expert"],
          "description": "Experience level."
        },
        "packs": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of experience packs."
        },
        "domains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Domains of expertise."
        },
        "highlights": {
          "type": "array",
          "items": { "$ref": "#/$defs/ExperienceHighlight" },
          "description": "Notable experience entries."
        }
      }
    },
    "ExperienceHighlight": {
      "type": "object",
      "required": ["id", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Experience pack ID."
        },
        "summary": {
          "type": "string",
          "description": "One-line summary."
        },
        "difficulty": {
          "type": "string",
          "enum": ["basic", "intermediate", "advanced", "expert"],
          "description": "Difficulty level."
        }
      }
    },
    "Collaboration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "can_delegate": {
          "type": "boolean",
          "default": false,
          "description": "Can delegate tasks to other agents."
        },
        "can_receive": {
          "type": "boolean",
          "default": true,
          "description": "Can receive tasks from other agents."
        },
        "protocols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported communication protocols."
        }
      }
    },
    "RuntimeRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported platforms (e.g. ['darwin', 'linux'])."
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "System dependencies (e.g. 'rust >= 1.75')."
        },
        "sandbox": {
          "type": "string",
          "enum": ["required", "recommended", "optional"],
          "default": "recommended",
          "description": "Sandbox requirement level."
        }
      }
    },
    "Marketplace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "description": "Primary category."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Search tags."
        },
        "pricing": {
          "$ref": "#/$defs/Pricing"
        },
        "stats": {
          "$ref": "#/$defs/Stats"
        }
      }
    },
    "Pricing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "enum": ["free", "one-time", "subscription", "usage"],
          "description": "Pricing model."
        },
        "base": {
          "type": "string",
          "description": "Base price (e.g. '$15/month')."
        },
        "trial": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of free trial runs."
        }
      }
    },
    "Stats": {
      "type": "object",
      "additionalProperties": false,
      "description": "Platform-managed stats (read-only for authors).",
      "properties": {
        "users": {
          "type": "integer",
          "minimum": 0
        },
        "rating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "tasks_completed": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
